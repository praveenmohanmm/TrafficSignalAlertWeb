@page "/"
@implements IAsyncDisposable
@inject GeolocationService GeoService
@inject TrafficSignalService SignalService
@inject AlertSettingsService SettingsService
@inject IJSRuntime JS

<PageTitle>Traffic Signal Alert</PageTitle>

<div class="tsa-app">

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <div class="tsa-header">
        <a class="tsa-settings-btn" href="settings" title="Settings">⚙</a>
        <h1>Traffic Signal Alert</h1>
        <p class="tsa-subtitle">Alerts you when approaching a traffic signal</p>
    </div>

    <!-- ── Out-of-range banner (alerts silenced) ──────────────────────── -->
    @if (GeoService.IsTracking && AlertRadius is null && !string.IsNullOrEmpty(_speedText))
    {
        <div class="tsa-stopped-banner">
            @if (SpeedKmh < 17)
            {
                <span>🛑 Too slow — alerts paused (&lt; 17 km/h)</span>
            }
            else
            {
                <span>⚠ Speed too high — alerts paused (&gt; 100 km/h)</span>
            }
        </div>
    }

    <!-- ── Alert banner ────────────────────────────────────────────────── -->
    @if (_isAlertActive)
    {
        <div class="tsa-alert @_alertClass">
            <div class="tsa-alert-title">⚠ SIGNAL NEARBY</div>
            @foreach (var line in _alertLines)
            {
                <div class="tsa-alert-line">@line</div>
            }
        </div>
    }

    <!-- ── Status message ──────────────────────────────────────────────── -->
    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="tsa-status @(_isError ? "tsa-status--error" : "")">@_statusMessage</div>
    }

    <!-- ── Closest signal card ──────────────────────────────────────────── -->
    <div class="tsa-card">
        <div class="tsa-card-row">
            <div class="tsa-card-label">Nearest Signal</div>
            <div class="tsa-card-distance">@_closestDistanceText</div>
        </div>
        <div class="tsa-card-value">@_closestSignalText</div>
        @if (!string.IsNullOrEmpty(_speedText))
        {
            <div class="tsa-card-sub tsa-speed @(_isMoving ? "tsa-speed--moving" : "tsa-speed--stopped")">
                @(_isMoving ? "Moving" : "Stopped") · @_speedText
            </div>
        }
    </div>

    <!-- ── Alert radius legend ──────────────────────────────────────────── -->
    <div class="tsa-card tsa-legend">
        <span>Alert radius: <strong>@(AlertRadius is null ? "—" : $"{AlertRadius} m")</strong></span>
        <span class="tsa-dot green"></span><span>≤@(AlertRadius?.ToString() ?? "—") m</span>
        <span class="tsa-dot orange"></span><span>≤60 m</span>
        <span class="tsa-dot red"></span><span>≤30 m</span>
    </div>

    <!-- ── Nearby signals list ──────────────────────────────────────────── -->
    @if (_isAlertActive && _nearbySignals.Count > 0)
    {
        <div class="tsa-card">
            <div class="tsa-card-label">Signals within alert radius</div>
            @foreach (var item in _nearbySignals)
            {
                <div class="tsa-nearby-row">
                    <span class="tsa-nearby-name">@item.Signal.IntersectionName</span>
                    <span class="tsa-nearby-type">@item.Signal.IntersectionType</span>
                    <span class="tsa-nearby-dist">@FormatDistance(item.DistanceMetres)</span>
                </div>
            }
        </div>
    }

    <!-- ── Loaded count ──────────────────────────────────────────────────── -->
    @if (_signalsLoaded > 0)
    {
        <div class="tsa-status">@_signalsLoaded signals loaded</div>
    }

    <!-- ── Controls ─────────────────────────────────────────────────────── -->
    <div class="tsa-controls">
        <button class="tsa-btn tsa-btn--start" @onclick="StartAsync" disabled="@GeoService.IsTracking">
            Start Tracking
        </button>
        <button class="tsa-btn tsa-btn--stop" @onclick="StopAsync" disabled="@(!GeoService.IsTracking)">
            Stop Tracking
        </button>
    </div>

</div>

@code {
    // ── State ────────────────────────────────────────────────────────────
    private string _positionText      = "Waiting for GPS…";
    private string _accuracyText      = string.Empty;
    private string _closestSignalText = "—";
    private string _closestDistanceText = "—";
    private string _statusMessage     = "Tap Start to begin tracking.";
    private bool   _isError;
    private bool   _isAlertActive;
    private string _alertClass        = string.Empty;
    private List<string> _alertLines  = [];
    private IReadOnlyList<(TrafficSignal Signal, double DistanceMetres)> _nearbySignals = [];
    private int _signalsLoaded;

    // ── Motion & audio state ─────────────────────────────────────────────
    /// <summary>Minimum speed in m/s to be considered moving (~5 km/h).</summary>
    private const double MovingThresholdMs  = 1.4;
    private const int    BeepCooldownSecs   = 10;
    private bool         _isMoving;
    private double       _speedMs;
    private string       _speedText         = string.Empty;
    private DateTime     _lastBeepUtc       = DateTime.MinValue;

    private double SpeedKmh => _speedMs * 3.6;
    /// <summary>Null when speed is outside the configured alertable range.</summary>
    private double? AlertRadius => SettingsService.Settings.GetAlertRadius(SpeedKmh);

    // ── Lifecycle ────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await SettingsService.LoadAsync();
        GeoService.LocationChanged += OnLocationChanged;
        GeoService.ErrorOccurred   += OnGeoError;
    }

    // ── Button handlers ──────────────────────────────────────────────────
    private async Task StartAsync()
    {
        _isError = false;
        _statusMessage = "Requesting GPS permission…";
        StateHasChanged();

        // Unlock Web Audio API during this user gesture (required on iOS)
        await JS.InvokeVoidAsync("trafficAudio.unlock");

        // Keep screen on so the browser doesn't suspend GPS
        await JS.InvokeVoidAsync("wakeLock.request");

        // Pre-load the signals file so the first GPS hit is instant
        if (_signalsLoaded == 0)
        {
            _statusMessage = "Loading signal data…";
            StateHasChanged();
            var signals = await SignalService.LoadSignalsAsync();
            _signalsLoaded = signals.Count;
        }

        await GeoService.StartAsync();

        if (GeoService.IsTracking)
        {
            _statusMessage = "Tracking active — updates on every GPS fix.";
        }
        StateHasChanged();
    }

    private async Task StopAsync()
    {
        await GeoService.StopAsync();
        await JS.InvokeVoidAsync("wakeLock.release");
        _isAlertActive = false;
        _alertLines    = [];
        _nearbySignals = [];
        _lastBeepUtc   = DateTime.MinValue;
        _statusMessage = "Tracking stopped.";
        StateHasChanged();
    }

    // ── Geolocation callbacks (arrive on threadpool → marshal to UI thread) ─
    private void OnLocationChanged(LocationResult loc)
    {
        _ = InvokeAsync(async () =>
        {
            _isError      = false;
            _positionText = $"{loc.Latitude:F6}° N,  {loc.Longitude:F6}° E";
            _accuracyText = $"±{loc.Accuracy:F0} m accuracy";
            _speedMs      = loc.Speed;
            _isMoving     = loc.Speed >= MovingThresholdMs;
            _speedText    = $"{loc.Speed * 3.6:F0} km/h";

            await UpdateProximityAsync(loc.Latitude, loc.Longitude);
            StateHasChanged();
        });
    }

    private void OnGeoError(string message)
    {
        _ = InvokeAsync(() =>
        {
            _isError       = true;
            _statusMessage = message;
            _isAlertActive = false;
            _alertLines    = [];
            _nearbySignals = [];
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    // ── Proximity logic ──────────────────────────────────────────────────
    private async Task UpdateProximityAsync(double lat, double lon)
    {
        var radius = AlertRadius;

        var (closest, closestDist) = await SignalService.GetClosestSignalAsync(lat, lon);
        if (closest is not null)
        {
            _closestSignalText   = $"{closest.IntersectionName}  [{closest.IntersectionType}]";
            _closestDistanceText = FormatDistance(closestDist);
        }

        // Suppress all alerts when speed is outside the 17–100 km/h window
        if (radius is null)
        {
            _isAlertActive = false;
            _alertLines    = [];
            _nearbySignals = [];
            return;
        }

        var nearby = await SignalService.GetNearbySignalsAsync(lat, lon, radius.Value);
        _nearbySignals = nearby;

        if (nearby.Count > 0)
        {
            var first = nearby[0];
            _isAlertActive = true;
            _alertClass    = first.DistanceMetres <= 30  ? "tsa-alert--red"
                           : first.DistanceMetres <= 60  ? "tsa-alert--orange"
                                                         : "tsa-alert--green";
            _alertLines =
            [
                first.Signal.IntersectionName,
                first.Signal.IntersectionType,
                $"{FormatDistance(first.DistanceMetres)} away"
            ];

            // ── Audio alert ──────────────────────────────────────────────
            // Fire as soon as any signal enters the configured radius (same
            // trigger as the visual banner). Beep intensity scales with distance.
            if ((DateTime.UtcNow - _lastBeepUtc).TotalSeconds >= BeepCooldownSecs)
            {
                _lastBeepUtc = DateTime.UtcNow;
                await JS.InvokeVoidAsync("trafficAudio.play",
                    first.DistanceMetres, radius.Value);
            }
        }
        else
        {
            _isAlertActive = false;
            _alertLines    = [];
        }
    }

    private static string FormatDistance(double m) =>
        m >= 1000 ? $"{m / 1000:F2} km" : $"{m:F0} m";

    // ── Cleanup ──────────────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        GeoService.LocationChanged -= OnLocationChanged;
        GeoService.ErrorOccurred   -= OnGeoError;
        await GeoService.DisposeAsync();
    }
}
